#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR=$(dirname "$(readlink -f "$0")")

exec "$SCRIPT_DIR/in-container" bash -lc 'python3 scripts/tasks/build_content.py && python3 scripts/tasks/build_linkgraph.py && python3 scripts/tasks/build_related.py && python3 scripts/tasks/build_indexes.py && python3 scripts/tasks/build_sidebar.py && npm run docs:build'
