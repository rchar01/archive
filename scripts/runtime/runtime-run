#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR=$(dirname "$(readlink -f "$0")")
# shellcheck source=./_container.sh
. "$SCRIPT_DIR/_container.sh"

build_runtime_image
container_id=$(run_runtime_container_background)
printf 'Started %s (%s) at http://localhost:%s\n' "$RUNTIME_CONTAINER_NAME" "$container_id" "$RUNTIME_PORT"
