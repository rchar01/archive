#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR=$(dirname "$(readlink -f "$0")")
# shellcheck source=./_container.sh
. "$SCRIPT_DIR/_container.sh"

build_image

if [ "${1:-}" = "--dev-port" ]; then
  shift
  run_container_with_dev_port "$(shell_join "$@")"
else
  run_container "$(shell_join "$@")"
fi
