SHELL := /bin/sh
ARCHIVE_DIR ?= ../archive
WORKSPACE := $(CURDIR)
ARCHIVE_INSTANCE ?= $(notdir $(CURDIR))
.DEFAULT_GOAL := help

.PHONY: help

help:
	$(MAKE) -C $(ARCHIVE_DIR) WORKSPACE="$(WORKSPACE)" ARCHIVE_INSTANCE="$(ARCHIVE_INSTANCE)" help

%:
	$(MAKE) -C $(ARCHIVE_DIR) WORKSPACE="$(WORKSPACE)" ARCHIVE_INSTANCE="$(ARCHIVE_INSTANCE)" $@
